JITFORGE_SERVER=http://127.0.0.1:8080
JITFORGE_GATEWAY_PORT=8090
JITFORGE_TOKEN=replace-with-a-long-random-token
JITFORGE_DATABASE_URL=postgres://jitforge:jitforge@127.0.0.1:5432/jitforge
JITFORGE_ARTIFACT_DIR=/var/lib/jitforge/artifacts
JITFORGE_LLM_BASE_URL=https://example.invalid/v1
JITFORGE_LLM_API_KEY=replace-me
JITFORGE_LLM_MODEL=replace-me
JITFORGE_LLM_VERIFIER_MODEL=replace-me
JITFORGE_LLM_THINKING=auto
JITFORGE_WORKER_TOKEN=replace-with-a-different-random-token
JITFORGE_SYNTHESIZER_MODE=openai
